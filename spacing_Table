<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Spacing</title>
    <style>
        h1 {
            text-align: center;

        }

        table.withSpacing {
            border-collapse: collapse;
            /* keep spacing visible */
            border-spacing: 15px;
            /* space between cells */
            width: 60%;
            margin: 20px auto;
            border: solid black;
            font-size: 40px;
        }

        /* Table with collapsed borders (no spacing between cells) */
        table.noSpacing {
            border-collapse: collapse;
            /* remove spacing between cells */
            width: 60%;
            margin: 20px auto;
            border: solid black;
            font-size: 30px;
        }

        th {
            padding: 10px;
            background-color: blueviolet;
            border: solid black;

        }


        td {
            border: 1px solid black;
            padding: 20px;
            border: solid black;

            /* space inside cells */
            text-align: center;
            background-color: #f9f9f9;
        }

        /* using hover function change the colour */
        td:hover {
            background-color: lightcoral;
        }
    </style>
</head>

<body>
    <h1>CALENDAR</h1>
    <table class="withSpacing">
        <tr>
            <th>Sun</th>
            <th>Mon</th>
            <th>Tue</th>
            <th>Wed</th>
            <th>Thu</th>
            <th>Fri</th>
            <th>Sat</th>
        </tr>
    </table>
    <table class="noSpacing">
        <tr>
            <td style="color: red;">1</td>
            <td>2</td>
            <td>3</td>
            <td>4</td>
            <td>5</td>
            <td>6</td>
            <td>7</td>
        </tr>
        <tr>
            <td style="color: red;">8</td>
            <td>9</td>
            <td>10</td>
            <td>11</td>
            <td>12</td>
            <td>13</td>
            <td>14</td>
        </tr>
        <tr>
            <td style="color: red;">15</td>
            <td>16</td>
            <td>17</td>
            <td>18</td>
            <td>19</td>
            <td>20</td>
            <td>21</td>
        </tr>
        <tr>
            <td style="color: red;">22</td>
            <td>23</td>
            <td>24</td>
            <td>25</td>
            <td>26</td>
            <td>27</td>
            <td>28</td>
        </tr>
        <tr>
            <td style="color: red;"> 29</td>
            <td>30</td>
            <td>31</td>
            <td></td>
            <td></td>
            <td></td>
            <td></td>
        </tr>
    </table>
</body>

</html>
